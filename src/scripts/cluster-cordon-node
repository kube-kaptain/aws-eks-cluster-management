# Cordon a single node to prevent new pods being scheduled on it
#
# Usage: cluster cordon node <node-name>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster cordon node <node-name>" >&2
  exit 1
fi

node_name="$1"

echo "Cordoning node ${node_name}..."
kubectl cordon "${node_name}"
echo "Node ${node_name} cordoned."
