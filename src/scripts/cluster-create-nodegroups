#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Create all EKS nodegroups defined in cluster.yaml
#
# Usage: cluster create nodegroups [--dry-run]
set -euo pipefail

approve="--approve"
case "${1:-}" in
  --dry-run)
    approve=""
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster create nodegroups [--dry-run]" >&2
    exit 1
    ;;
esac

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Creating all nodegroups on cluster ${cluster_name}..."
# shellcheck disable=SC2086 # approve must word-split when set, disappear when empty
eksctl create nodegroup -f "${CLUSTER_CONFIG}" ${approve}

echo ""
if [[ -z "${approve}" ]]; then
  echo "Dry run complete. No changes were made."
else
  echo "All nodegroups created successfully."
fi
