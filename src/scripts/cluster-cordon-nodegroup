#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Cordon all nodes in a nodegroup
#
# Usage: cluster cordon nodegroup <nodegroup-name>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster cordon nodegroup <nodegroup-name>" >&2
  exit 1
fi

if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster cordon nodegroup <nodegroup-name>" >&2
  exit 1
fi

nodegroup_name="$1"

nodes=$(kubectl get nodes -l "eks.amazonaws.com/nodegroup=${nodegroup_name}" -o jsonpath='{.items[*].metadata.name}')

if [[ -z "${nodes}" ]]; then
  echo "No nodes found in nodegroup ${nodegroup_name}"
  exit 0
fi

echo "Cordoning all nodes in nodegroup ${nodegroup_name}..."
for node in ${nodes}; do
  echo "  Cordoning ${node}..."
  kubectl cordon "${node}"
done
echo "All nodes in nodegroup ${nodegroup_name} cordoned."
