#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Delete all EKS addons not defined in cluster.yaml
#
# Shows which addons will be deleted and requires confirmation unless
# --yes is passed. Bails if no addons are configured to avoid
# accidentally removing all addons from the cluster.
#
# Usage: cluster delete addons [--yes]
set -euo pipefail

confirm=true
case "${1:-}" in
  --yes)
    confirm=false
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster delete addons [--yes]" >&2
    exit 1
    ;;
esac

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster delete addons [--yes]" >&2
  exit 1
fi

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

has_addons=$(yq '.addons // ""' "${CLUSTER_CONFIG}")
if [[ -z "${has_addons}" || "${has_addons}" == "null" ]]; then
  echo "Addons key not found in ${CLUSTER_CONFIG}, cannot determine what to keep."
  echo "Skipping deletion to avoid removing all addons."
  exit 0
fi

has_entries=$(yq '.addons // "" | length' "${CLUSTER_CONFIG}")
if [[ "${has_entries}" -eq 0 ]]; then
  echo "No addons defined in ${CLUSTER_CONFIG}, cannot determine what to keep."
  echo "Skipping deletion to avoid removing all addons."
  exit 0
fi

# Get addon names defined in cluster.yaml
configured_addons=$(yq '.addons[].name' "${CLUSTER_CONFIG}")

# Get addon names currently on the cluster
live_addons=$(eksctl get addons --cluster "${cluster_name}" -o yaml | yq -r '.[].Name')

# Build list of addons not in cluster.yaml
extras=()
for addon in ${live_addons}; do
  if ! echo "${configured_addons}" | grep -qx "${addon}"; then
    extras+=("${addon}")
  fi
done

if [[ ${#extras[@]} -eq 0 ]]; then
  echo "No extra addons found."
  exit 0
fi

if [[ "${confirm}" == "true" ]]; then
  echo "Will delete the following ${#extras[@]} addon(s) not defined in cluster.yaml:"
  for addon in "${extras[@]}"; do
    echo "  ${addon}"
  done
  printf "Type 'yes' to proceed: "
  read -r answer
  if [[ "${answer}" != "yes" ]]; then
    echo "Aborted."
    exit 0
  fi
fi

for addon in "${extras[@]}"; do
  "${CLUSTER_SCRIPT_DIR}/cluster-delete-addon" "${addon}"
done

echo "Deleted ${#extras[@]} extra addon(s)."
