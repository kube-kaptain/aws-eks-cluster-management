#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Delete an EKS addon
#
# Usage: cluster delete addon <addon-name>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster delete addon <addon-name>" >&2
  exit 1
fi

if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster delete addon <addon-name>" >&2
  exit 1
fi

addon_name="$1"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Deleting addon ${addon_name} from cluster ${cluster_name}..."
eksctl delete addon --cluster "${cluster_name}" --name "${addon_name}"
echo "Addon ${addon_name} deleted."
