#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Poll until an EKS insights refresh completes for the cluster
#
# Usage: cluster poll-insights-refresh
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster poll-insights-refresh" >&2
  exit 1
fi

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Polling insights refresh status for ${cluster_name}..."
while true; do
  status=$(AWS_PAGER="" aws eks describe-insights-refresh --cluster-name "${cluster_name}" --query 'status' --output text)
  case "${status}" in
    COMPLETED)
      echo "Insights refresh completed."
      break
      ;;
    FAILED)
      echo "ERROR: Insights refresh failed." >&2
      AWS_PAGER="" aws eks describe-insights-refresh --cluster-name "${cluster_name}"
      exit 1
      ;;
    *)
      echo "Status: ${status} - waiting..."
      sleep 5
      ;;
  esac
done
