#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Shorthand for kubectl -n default
#
# Usage: k-default <kubectl-args...>
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: k-default <kubectl-args...>" >&2
  exit 1
fi

exec kubectl -n default "$@"
